{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duck.ai",
  "version": "0.1.0",
  "identifier": "com.your-domain.your-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "ssb": {
      "url": "https://duck.ai/"
    }
  }
}
